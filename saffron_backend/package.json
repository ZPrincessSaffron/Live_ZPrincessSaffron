{
  "name": "saffron_backend",
  "version": "1.0.0",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --detectOpenHandles",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js src/tests/unit/ --runInBand",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js src/tests/integration/ --runInBand",
    "test:database": "node --experimental-vm-modules node_modules/jest/bin/jest.js src/tests/database/ --runInBand",
    "test:api": "newman run src/tests/api/saffron.postman_collection.json -e src/tests/api/env.json",
    "test:load": "k6 run src/tests/performance/load_test.js",
    "test:e2e": "cd ../saffron_frontend && npx cypress run",
    "test:full": "npm test && npm run test:api",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "country-state-city": "^3.2.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.5.0",
    "groq-sdk": "^0.37.0",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.0",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.4",
    "razorpay": "^2.9.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2",
    "husky": "^9.0.11"
  }
}
