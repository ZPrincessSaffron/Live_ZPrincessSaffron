# MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/dbname

# CORS Allowed Origins (comma separated)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app

# Server port
PORT=5000

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here

# Google OAuth Client ID (Backend)
GOOGLE_CLIENT_ID=your_google_client_id

# Razorpay Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Email Configuration (Nodemailer)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

# Groq AI API Key
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Firebase Admin Configuration
# Format: JSON string containing the service account details
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"...","universe_domain":"..."}'
